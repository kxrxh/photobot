    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "daisyui": "^5.5.23",
    "jsdom": "^29.1.1",
    "knip": "^6.16.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
