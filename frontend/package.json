    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tma.js/bridge": "^2.3.0",
    "@tma.js/types": "^1.0.2",
    "framer-motion": "^12.40.0",
    "jose": "^6.2.3",
    "ky": "^1.14.3",
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^9.16.0",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.7",
    "@tanstack/router-plugin": "^1.168.18",
