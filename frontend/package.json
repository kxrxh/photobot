{
  "name": "photobot",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "bunx @biomejs/biome lint src",
    "format": "bunx @biomejs/biome format --write src",
    "preview": "vite preview",
    "test": "vitest",
