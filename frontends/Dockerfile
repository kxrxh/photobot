FROM node:20-bookworm-slim AS builder

ARG VITE_HOST
ARG VITE_BASE_PATH=/
ARG VITE_AUTH_API_URL
ARG VITE_WEED_API_URL
ARG VITE_CLASSIFICATION_API_URL
ARG VITE_ANALYSIS_API_URL
ARG VITE_REPORTS_API_URL

ENV VITE_HOST=$VITE_HOST
ENV VITE_BASE_PATH=$VITE_BASE_PATH
ENV VITE_AUTH_API_URL=$VITE_AUTH_API_URL
ENV VITE_WEED_API_URL=$VITE_WEED_API_URL
ENV VITE_CLASSIFICATION_API_URL=$VITE_CLASSIFICATION_API_URL
ENV VITE_ANALYSIS_API_URL=$VITE_ANALYSIS_API_URL
ENV VITE_REPORTS_API_URL=$VITE_REPORTS_API_URL

WORKDIR /app
RUN npm install -g bun
COPY package.json bun.lock ./
RUN bun install --frozen-lockfile
COPY . ./
RUN bun run build

FROM nginxinc/nginx-unprivileged:stable-alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY default.conf /etc/nginx/conf.d/default.conf
EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]