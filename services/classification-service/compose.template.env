# ===========================================
# CLASSIFICATION SERVICE CONFIGURATION
# ===========================================

# ---------------------------
# Main Service Configuration
# ---------------------------
SERVER_PORT=6020

# Trust X-Forwarded-For when the direct peer is a private proxy (e.g. Docker/nginx).
HTTP_TRUST_PROXY=true
HTTP_TRUST_PRIVATE_PROXIES=true

# ---------------------------
# Database Configuration
# ---------------------------
DB_HOST=database
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=classification_db
DB_SSLMODE=disable
DB_MAX_CONNS=50
DB_MIN_CONNS=2

# ---------------------------
# Redis Configuration (shared rate limiter storage)
# ---------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------------------------
# Service Integration
# ---------------------------
AUTH_SERVICE_URL=
CORRELATION_SERVICE_URL=

# ---------------------------
# Authentication & Security
# ---------------------------
SERVICE_ID=classification-service
SERVICE_SECRET=
RATE_LIMIT_MAX=120
RATE_LIMIT_EXPIRATION_SEC=60

# ---------------------------
# Debug Settings
# ---------------------------
DEBUG=false
