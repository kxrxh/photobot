# Copy to .env for compose variable substitution (DOMAIN, etc.)
# Also copy to compose.env for backend service env_file
SERVER_PORT=6030
AUTH_SERVICE_URL=
RATE_LIMIT_MAX=120
RATE_LIMIT_EXPIRATION_SEC=60
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

DB_HOST=database
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=photobot_db
DB_MAX_CONNS=10
DB_MIN_CONNS=2
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=5m

MINIO_HOST=minio
MINIO_PORT=9000

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

DOMAIN=

MINIO_BROWSER_REDIRECT_URL=https://${DOMAIN}/minio-console
MINIO_PUBLIC_ENDPOINT=https://${DOMAIN}/minio-api

DEBUG=false