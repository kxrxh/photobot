# AuthService env. Align with photobot-infra config/services/auth-service.yaml.
# Copy to compose.env for local dev. For deploy, paste into COMPOSE_ENVS auth-service block.

HOST=0.0.0.0
PORT=6010
HEALTH_CACHE_TTL_SEC=10
CORS_ALLOW_ORIGINS=*

DB_HOST=database
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=auth_db
DB_SSLMODE=disable
DB_MAX_CONNS=50
DB_MIN_CONNS=2

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=50

ADMIN_LOGIN=
ADMIN_PASSWORD=
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_MINUTES=10080
ENCRYPTION_KEY=
RSA_PRIVATE_KEY_PATH=/etc/auth-service/keys/private.pem
RSA_PUBLIC_KEY_PATH=/etc/auth-service/keys/public.pem

MERGE_CLASSIFICATION_SERVICE_URL=
MERGE_ANALYSIS_SERVICE_URL=

RATE_LIMIT_MAX=10
RATE_LIMIT_EXPIRATION_SEC=60

DEBUG=false
DEBUG_BYPASS_SIGNATURES=false